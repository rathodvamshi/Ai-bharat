# ============================================
# Root .gitignore for Jan-Sahayak Project
# ============================================

# Environment Variables (CRITICAL - Contains AWS Credentials)
.env
.env.local
.env.development
.env.test
.env.production
*.env

# AWS Credentials
.aws/
aws-credentials.json

# Python artifacts
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
# lib/ - Removed: was blocking frontend/app/lib
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual Environments
venv/
env/
ENV/
env.bak/
venv.bak/

# IDE / Editor files
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# OS Files
Thumbs.db
*.log

# Temporary / Cache Files
*.cache
.pytest_cache/
.coverage
htmlcov/

# Audio files (Generated by backend)
backend/static/*.mp3
backend/static/*.webm
*.mp3
*.webm
*.wav

# SAM / CloudFormation
.aws-sam/
samconfig.toml

# Node modules (covered by frontend .gitignore but safe to add here too)
node_modules/

# Next.js build output
.next/
out/

# Terraform (if you add IaC later)
*.tfstate
*.tfstate.backup
.terraform/